# Environment for app (local, dev, staging, production)
ENVIRONMENT=dev

# Backend API URL (server-side only — never expose to browser)
API_URL=http://localhost:3002
# Backend API URL (client-side — only if making direct browser requests)
NEXT_PUBLIC_API_URL=http://localhost:3002

# Base URL for the application (used in sitemap and other places)
NEXT_PUBLIC_BASE_URL=https://zentavos.com

# Mobile App Scheme (com.zentavos.zentavoslocal, com.zentavos.zentavosdev, com.zentavos.zentavosuat, or com.zentavos.mobile)
NEXT_PUBLIC_MOBILE_APP_SCHEME=com.zentavos.zentavoslocal

# Database (SQLite for dev, replace with PostgreSQL URL for production)
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# SMTP (for password recovery emails)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@zentavos.com"

# Salesforce CRM Integration (Lead capture)
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_SECURITY_TOKEN=
SALESFORCE_INSTANCE_URL=https://login.salesforce.com
